# Shared
NODE_ENV=development
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
AETHER_MINT=<devnet_test_aether_mint>
TREASURY_WALLET=<treasury_wallet_public_key>
TREASURY_TOKEN_ACCOUNT=<treasury_associated_token_account_for_AETHER>

# Server only
SERVER_PORT=8787
CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=replace-with-random-long-secret
DATABASE_URL=postgres://chronofrost:chronofrost@localhost:5432/chronofrost

# Never commit real private keys. For devnet scripts only.
DEVNET_PAYER_KEYPAIR_PATH=~/.config/solana/id.json

# PvP admin/studio-funded season config
PVP_ADMIN_TOKEN=change-me-admin-token
PVP_SEASON_ID=season-1
PVP_PRIZE_POOL_RAW=0
PVP_PRIZE_DISTRIBUTION=0.5,0.3,0.2
PVP_TOKEN_DECIMALS=6

# PvP prize eligibility / anti-sybil rules
# Production recommendation: account age >=7 days, completed matches >=30,
# unique opponents >=10, repeated-opponent cap <=3.
PVP_SEASON_CUTOFF_AT=9999-12-31T00:00:00.000Z
PVP_MIN_ACCOUNT_AGE_DAYS=7
PVP_MIN_COMPLETED_MATCHES=30
PVP_MIN_UNIQUE_OPPONENTS=10
PVP_MAX_COUNTED_MATCHES_PER_OPPONENT=3
PVP_MAX_FORFEIT_RATE=0.2
PVP_SHORT_MATCH_MAX_ACTIONS=3
PVP_MAX_SHORT_MATCH_RATE=0.35
PVP_MAX_IDENTITY_CLUSTER_SIZE=3
PVP_FINGERPRINTING_ENABLED=false
PVP_FINGERPRINT_SALT=replace-with-random-salt-if-fingerprinting-enabled
PVP_TEST_WALLET_PREFIXES=test-,dev-,wallet-route-
PVP_ADMIN_EXCLUDED_WALLETS=

# Phase 5 / agent-friendly next build
PVP_STORAGE_ADAPTER=memory
PVP_QUEUE_RATE_LIMIT_MAX=12
PVP_QUEUE_RATE_LIMIT_WINDOW_MS=60000
PVP_ACTION_RATE_LIMIT_MAX=60
PVP_ACTION_RATE_LIMIT_WINDOW_MS=60000
PVP_ADMIN_RATE_LIMIT_MAX=60
PVP_ADMIN_RATE_LIMIT_WINDOW_MS=60000
