{
  "name": "chronofrost-aetherbound-fixed",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @chronofrost/client dev",
    "dev:server": "pnpm --filter @chronofrost/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "ci": "pnpm verify",
    "migrate:pvp": "node scripts/migrate-pvp.mjs",
    "agent:context": "node scripts/agent-context-pack.mjs",
    "agent:preflight": "node scripts/agent-preflight.mjs",
    "architecture:guard": "node scripts/architecture-guard.mjs",
    "smoke:launch": "node scripts/launch-smoke.mjs",
    "readiness:devnet": "node -e \"process.env.LAUNCH_TARGET='devnet'; import('./scripts/launch-readiness.mjs')\"",
    "readiness:mainnet": "node -e \"process.env.LAUNCH_TARGET='mainnet'; import('./scripts/launch-readiness.mjs')\"",
    "verify:agent": "pnpm agent:preflight && pnpm architecture:guard && pnpm verify"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4"
  }
}
